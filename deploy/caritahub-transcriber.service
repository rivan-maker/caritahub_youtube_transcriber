[Unit]
Description=CaritaHub YouTube Transcriber
After=network.target

[Service]
Type=simple
User=__RUN_USER__
Group=__RUN_USER__
WorkingDirectory=__APP_DIR__
EnvironmentFile=/etc/caritahub-transcriber.env
ExecStart=__APP_DIR__/.venv/bin/uvicorn server:app --host 0.0.0.0 --port 8000 --workers 1 --timeout-keep-alive 75
Restart=on-failure
RestartSec=5
MemoryMax=3G
TimeoutStopSec=60

[Install]
WantedBy=multi-user.target
